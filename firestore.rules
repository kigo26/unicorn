rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'authorId', 'authorName', 'rating', 'content', 'createdAt'])
        && data.keys().size() == 6
        && data.productId is string && data.productId.size() > 0 && data.productId.size() <= 128
        && data.authorId is string && data.authorId.size() > 0 && data.authorId.size() <= 128
        && data.authorName is string && data.authorName.size() > 0 && data.authorName.size() <= 128
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.content is string && data.content.size() >= 0 && data.content.size() <= 2000
        && (
             (isSignedIn() && data.authorId == request.auth.uid) || 
             (!isSignedIn() && data.authorId == 'anonymous') ||
             (isSignedIn() && data.authorId == 'anonymous')
           );
    }

    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isValidId(reviewId) 
                    && isValidReview(incoming())
                    && incoming().createdAt == request.time;
      allow update, delete: if false;
    }
  }
}
